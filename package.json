{
  "name": "forgelet",
  "version": "0.1.0",
  "description": "Local-first CLI coding agent for small repository tasks.",
  "type": "module",
  "bin": {
    "forge": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "fixtures",
    "README.md",
    "ARCHITECTURE.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node dist/browser/extension/buildExtension.js",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "smoke:deepseek": "npm run build && node dist/models/providers/deepseekSmoke.js",
    "smoke:writing": "npm run build && node dist/smoke/writingCreative.js",
    "smoke:learning": "npm run build && node dist/smoke/learning.js",
    "clean": "rm -rf dist dist-test"
  },
  "keywords": [
    "agent",
    "cli",
    "coding-agent",
    "local-first"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  }
}

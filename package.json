{
  "name": "forgelet",
  "version": "0.1.0",
  "description": "Local-first CLI coding agent for small repository tasks.",
  "type": "module",
  "bin": {
    "forge": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "ARCHITECTURE.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "npm run build && tsc -p tsconfig.test.json && node dist-test/tests/run.js",
    "smoke:deepseek": "npm run build && node dist/models/providers/deepseekSmoke.js",
    "clean": "rm -rf dist dist-test"
  },
  "keywords": [
    "agent",
    "cli",
    "coding-agent",
    "local-first"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=16.14"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.9.3"
  }
}
